# Normalize line endings
* text=auto eol=lf

# Python
*.py text=auto eol=lf

# Documentation
*.md text=auto eol=lf

# Configuration
*.cfg text=auto eol=lf
*.toml text=auto eol=lf
*.yaml text=auto eol=lf
*.yml text=auto eol=lf
*.json text=auto eol=lf

# Shell scripts
*.sh text=auto eol=lf

# Git
.git/** text=auto eol=lf
.gitignore text=auto eol=lf
.gitattributes text=auto eol=lf